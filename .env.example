# Frontend Environment Variables
VITE_API_URL=http://localhost:5000

# Backend Environment Variables (for backend/.env)
PORT=5000
NODE_ENV=development
PERFECT_API_KEY=PASTE_YOUR_PERFECT_API_KEY_HERE
PERFECT_API_BASE_URL=https://yce-api-01.makeupar.com
PERFECT_V1_API_BASE_URL=https://yce-api-01.makeupar.com
PERFECT_DEMO_MODE=false
PERFECT_API_POLL_INTERVAL_MS=2000
PERFECT_API_MAX_ATTEMPTS=45

# Optional/conditional Perfect v1 image-generation credentials.
# Fill these only if the Perfect Corp API Console requires v1 access-token/client authentication.
PERFECT_V1_ACCESS_TOKEN=PASTE_IF_REQUIRED
PERFECT_V1_CLIENT_ID=PASTE_IF_REQUIRED
PERFECT_V1_CLIENT_SECRET=PASTE_IF_REQUIRED
PERFECT_TEXT_STYLE_GROUP_ID=PASTE_IF_REQUIRED
PERFECT_TEXT_STYLE_ID=PASTE_IF_REQUIRED

# Optional Gemini enrichment for turning raw Perfect Corp analysis into friendly UI copy.
# Keep this server-side only; do not expose it as VITE_*.
GEMINI_API_KEY=PASTE_IF_REQUIRED
GEMINI_MODEL=gemini-2.5-flash
