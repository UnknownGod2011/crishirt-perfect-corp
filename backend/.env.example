# Backend Environment Variables — copy to backend/.env and fill in real values

PORT=5000
NODE_ENV=production

# Perfect Corp API key (required)
PERFECT_API_KEY=PASTE_YOUR_PERFECT_API_KEY_HERE
PERFECT_API_BASE_URL=https://yce-api-01.makeupar.com
PERFECT_V1_API_BASE_URL=https://yce-api-01.makeupar.com
PERFECT_DEMO_MODE=false
PERFECT_API_POLL_INTERVAL_MS=2000
PERFECT_API_MAX_ATTEMPTS=45

# Perfect Corp v1 credentials (fill if API Console requires client auth)
PERFECT_V1_ACCESS_TOKEN=PASTE_IF_REQUIRED
PERFECT_V1_CLIENT_ID=PASTE_IF_REQUIRED
PERFECT_V1_CLIENT_SECRET=PASTE_IF_REQUIRED

# Perfect Corp text-to-image style IDs (Contemporary > Pop Art)
PERFECT_TEXT_STYLE_GROUP_ID=13600722
PERFECT_TEXT_STYLE_ID=5257

# Gemini API — enriches skin analysis into consumer-friendly copy (optional but recommended)
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
